# Supabase — get these from your project dashboard at supabase.com
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Acuity Scheduling — get these from Acuity > Integrations > API
ACUITY_USER_ID=your-acuity-user-id
ACUITY_API_KEY=your-acuity-api-key

# RingCentral SMS — Production credentials, set on Vercel production env only.
# JWT is generated in the RingCentral app dashboard (Credentials tab).
RINGCENTRAL_CLIENT_ID=<from-ringcentral-dashboard>
RINGCENTRAL_CLIENT_SECRET=<from-ringcentral-dashboard>
RINGCENTRAL_JWT=<from-ringcentral-dashboard>
RINGCENTRAL_SERVER_URL=https://platform.ringcentral.com
